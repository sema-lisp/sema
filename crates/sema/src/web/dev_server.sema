;; dev_server.sema — the `sema web` dev server.
;;
;; Launched by crates/sema/src/web/mod.rs, which injects `__web-config-json`
;; (a JSON string) and runs this file. The server never evaluates the app's
;; Sema — the browser WASM runtime does. Its job is plumbing: serve the embedded
;; browser runtime + a synthesized HTML shell + the app's source files.

(define config (json/decode __web-config-json))
(define host (:host config))
(define port (:port config))
(define entry (:entry config))
(define runtime-dir (:runtimeDir config))
(define app-dir (:appDir config))
(define build-dir (:buildDir config))

;; How the browser loads the app: single-file apps run from raw source; an app
;; that uses `import` can't resolve modules against the browser's (absent) fs, so
;; it's compiled to a `.vfs` under build-dir and served from /__build. `__web/prepare`
;; (native) decides + (re)builds, returning {:mode "source"|"archive"|"error"}.
(define app-state (__web/prepare))
(define app-mode (:mode app-state))
(define app-error (:error app-state))

;; Watch the app dir; each poll drains pending events and, if any fired, bumps a
;; generation the browser diffs against to trigger a reload. fs/watch emits
;; several events per save, but coalescing them into one bump per poll debounces.
;; The generation also cache-busts the app-source URL (:static sends a 1h
;; cache-control), so a full reload fetches the changed source instead of a copy.
(define watcher (fs/watch app-dir))
(define generation 0)

(define llm-enabled (:llm config))

;; The tag that loads the app: raw source for single-file apps, the compiled
;; .vfs for multi-file, or a visible build error. Generation cache-busts it.
(define (app-script-tag)
  (cond
    ((equal? app-mode "error")
     (string-append
       "<pre style=\"margin:1rem;padding:1rem;background:#7f1d1d;color:#fee2e2;"
       "border-radius:8px;white-space:pre-wrap;font:13px/1.5 ui-monospace,monospace\">"
       "Build error:\n" (or app-error "") "</pre>\n"))
    ((equal? app-mode "archive")
     (string-append "<script type=\"text/sema\" src=\"/__build/app.vfs?g="
                    (number->string generation) "\"></script>\n"))
    (else
     (string-append "<script type=\"text/sema\" src=\"/app/" entry "?g="
                    (number->string generation) "\"></script>\n"))))

;; The synthesized page. An <script type="importmap"> resolves the bare
;; @sema-lang/* specifiers to the runtime we serve under /__sema; the app loads
;; via app-script-tag; SemaWeb.init() boots it and flags readiness for e2e.
(define (shell-html)
  (string-append
    "<!DOCTYPE html>\n"
    "<html lang=\"en\">\n<head>\n"
    "<meta charset=\"utf-8\">\n"
    "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
    "<link rel=\"icon\" href=\"data:,\">\n"
    "<title>Sema Web — " entry "</title>\n"
    "<script type=\"importmap\">\n"
    "{\n  \"imports\": {\n"
    "    \"@sema-lang/sema-web\": \"/__sema/sema-web.js\",\n"
    "    \"@sema-lang/sema\": \"/__sema/sema/index.js\",\n"
    "    \"@sema-lang/sema-wasm\": \"/__sema/sema_wasm.js\",\n"
    "    \"@preact/signals-core\": \"/__sema/signals-core.module.js\",\n"
    "    \"morphdom\": \"/__sema/morphdom-esm.js\"\n"
    "  }\n}\n"
    "</script>\n</head>\n<body>\n"
    "<div id=\"app\"></div>\n"
    (app-script-tag)
    "<script type=\"module\">\n"
    "  import { SemaWeb } from \"@sema-lang/sema-web\";\n"
    ;; Dev-only error overlay: surface Sema init/app errors on the page instead
    ;; of only in the console. The loader logs app-eval errors via console.error,
    ;; so hooking it catches those too. Cleared on the next successful reload.
    "  function __semaError(msg){\n"
    "    let el=document.getElementById('__sema-error');\n"
    "    if(!el){el=document.createElement('div');el.id='__sema-error';\n"
    "      el.style.cssText='position:fixed;left:0;right:0;top:0;z-index:99999;background:#7f1d1d;color:#fee2e2;font:13px/1.5 ui-monospace,monospace;padding:12px 16px;white-space:pre-wrap;box-shadow:0 2px 12px rgba(0,0,0,.35);cursor:pointer';\n"
    "      el.title='click to dismiss';el.onclick=()=>el.remove();document.body.appendChild(el);}\n"
    "    el.textContent='\\u26a0 Sema error:\\n'+msg;\n"
    "  }\n"
    "  const __origErr=console.error;\n"
    "  console.error=function(){__origErr.apply(console,arguments);\n"
    "    const m=Array.from(arguments).map(String).join(' ');\n"
    "    if(m.indexOf('[sema')>=0||m.indexOf('Error in')>=0)__semaError(m);};\n"
    "  try {\n"
    ;; With the proxy enabled, point the browser's llm/* at this same origin —
    ;; the dev server answers /complete, /chat, /stream, ... with server keys.
    (if llm-enabled
      "    await SemaWeb.init({ llmProxy: window.location.origin });\n"
      "    await SemaWeb.init();\n")
    "    window.__semaInitialized = true;\n"
    "  } catch (e) {\n"
    "    window.__semaInitError = String((e && e.message) || e);\n"
    "    __semaError(String((e && e.message) || e));\n"
    "    console.error(e);\n"
    "  }\n"
    "</script>\n"
    ;; Hot reload: short-poll /__dev/poll (each returns instantly, so it never
    ;; blocks the sequential server) and full-reload when the generation bumps.
    "<script>\n"
    "(function(){var g=null;function p(){"
    "fetch('/__dev/poll').then(function(r){return r.ok?r.json():null;})"
    ".then(function(d){if(d){if(g===null){g=d.generation;}"
    "else if(d.generation!==g){location.reload();return;}}setTimeout(p,300);})"
    ".catch(function(){setTimeout(p,600);});}p();})();\n"
    "</script>\n"
    "</body>\n</html>\n"))

(define (handle-index req)
  (http/html (shell-html)))

(define (handle-poll req)
  (when (> (length (fs/watch-events watcher)) 0)
    ;; Re-decide mode + rebuild the archive so edits (and added/removed imports)
    ;; take effect on reload.
    (let ((st (__web/prepare)))
      (set! app-mode (:mode st))
      (set! app-error (:error st)))
    (set! generation (+ generation 1)))
  (http/ok {:generation generation}))

;; --- LLM proxy (enabled unless --no-llm) ------------------------------------
;; Speaks the same protocol as @sema-lang/llm-proxy so the browser client works
;; unchanged; each handler just calls native llm/* with the server's env keys.
;; The request body carries the model/options the app passed, so it is forwarded
;; as the opts map (llm/* reads only the keys it knows).

;; The browser sends messages as JSON {role, content}; native llm/* wants
;; message values with keyword roles.
(define (->messages b)
  (map (fn (m) (message (string->keyword (:role m)) (:content m)))
       (:messages b)))

(define (handle-complete req)
  (let ((b (:json req)))
    (http/ok {:content (llm/complete (:prompt b) b)})))

(define (handle-chat req)
  (let ((b (:json req)))
    (http/ok {:content (llm/chat (->messages b) b)})))

(define (handle-extract req)
  (let ((b (:json req)))
    (http/ok (llm/extract (:schema b) (:text b) b))))

(define (handle-classify req)
  (let ((b (:json req)))
    (http/ok {:category (llm/classify (:categories b) (:text b) b)})))

(define (handle-embed req)
  (let ((b (:json req)))
    (http/ok {:embedding (llm/embed (:text b) b)})))

(define (handle-models req)
  (http/ok {:models (llm/list-providers)}))

;; Streaming endpoint: emit one SSE `data:` per token as {type:"token",text},
;; then {type:"done"} — the shape sema-web's SSE client expects. Tokens stream
;; progressively (the SSE channel is unbounded, so llm/stream's per-chunk
;; callback can feed it from inside the provider's runtime without blocking).
;;
;; Note: while a stream is live it holds the single evaluator thread, so other
;; requests queue behind it (head-of-line blocking — the deferred M2 concurrency
;; work). Fine for a single-user dev loop.
(define (handle-stream req)
  (let ((b (:json req)))
    (http/stream
      (fn (send)
        (llm/stream (->messages b)
          (fn (chunk) (send (json/encode {:type "token" :text chunk})))
          b)
        (send (json/encode {:type "done"}))))))

;; /__sema/*    → embedded runtime (WASM + JS bundle), served with real MIME types.
;; /app/*       → the app's source directory (raw .sema + any assets).
;; /__dev/poll  → hot-reload generation (instant response; never blocks).
(define base-routes
  [[:get    "/"           handle-index]
   [:get    "/__dev/poll" handle-poll]
   [:static "/__sema"     runtime-dir]
   [:static "/__build"    build-dir]
   [:static "/app"        app-dir]])

(define llm-routes
  [[:post "/complete" handle-complete]
   [:post "/chat"     handle-chat]
   [:post "/stream"   handle-stream]
   [:post "/extract"  handle-extract]
   [:post "/classify" handle-classify]
   [:post "/embed"    handle-embed]
   [:get  "/models"   handle-models]])

(define routes
  (if llm-enabled (append base-routes llm-routes) base-routes))

(define (announce info)
  (println "")
  (println (string-append "  Sema Web dev server"))
  (println (string-append "  → " (:url info)))
  (println (string-append "  serving " entry " from " app-dir))
  (println ""))

(http/serve (http/router routes)
  {:host host
   :port port
   :port-fallback true
   :on-listen announce})
