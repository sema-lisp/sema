;; Pico Jukebox
;;
;;   GP20 = PLAY current song
;;   GP22 = NEXT song (wraps around)

(define pico (serial/open "/dev/tty.usbmodem1201" 115200 3000))
(define (cmd s) (serial/send pico s))
(try (serial/read-line pico) (catch e nil))
(cmd "PING")

(define (led! pin val) (cmd (str "PIN_SET " pin " " val)))
(define (leds-off) (dotimes (i 8) (led! i 0)))
(define (neo! r g b) (cmd (str "NEOPIXEL 1 0 " r " " g " " b)))

(define (freq->led freq)
  (cond
    ((< freq 100) 0)
    ((< freq 150) 1)
    ((< freq 200) 2)
    ((< freq 250) 3)
    ((< freq 300) 4)
    ((< freq 350) 5)
    ((< freq 400) 6)
    (else 7)))

(define (freq->color freq)
  (cond
    ((< freq 100) (list 40 0 0))
    ((< freq 150) (list 80 20 0))
    ((< freq 200) (list 60 60 0))
    ((< freq 250) (list 0 80 0))
    ((< freq 300) (list 0 60 60))
    ((< freq 350) (list 0 20 80))
    ((< freq 400) (list 40 0 80))
    (else (list 80 0 60))))

(define song-names
  (vector "Moon Loves The Sun"
    "Out of the Blue"
    "Seven Cities"
    "Airwave (Rank 1)"
    "Beautiful Life"
    "Icarus"))

(define song-colors
  (vector (list 0 40 80)
    (list 0 80 40)
    (list 80 40 0)
    (list 40 0 80)
    (list 80 0 40)
    (list 80 80 0)))

