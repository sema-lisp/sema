(define num-songs 6)

(define (show-selection idx)
  (leds-off)
  (let ((lit (/ (* idx 7) (- num-songs 1))))
    (dotimes (i 8) (led! i (if (<= i lit) 1 0))))
  (let ((rgb (nth song-colors idx)))
    (neo! (nth rgb 0) (nth rgb 1) (nth rgb 2))))

(define (play-song notes)
  (let ((start (time/now)))
    (define (ms) (floor (* (- (time/now) start) 1000)))
    (define (go remaining)
      (when (not (null? remaining))
        (let ((note (car remaining)))
          (let ((target (car note))
                (freq (nth note 1))
                (dur (nth note 2)))
            (let ((wait (- target (ms))))
              (when (> wait 0) (sleep wait)))
            (let ((lp (freq->led freq))
                  (rgb (freq->color freq)))
              (leds-off)
              (led! lp 1)
              (neo! (nth rgb 0) (nth rgb 1) (nth rgb 2)))
            (cmd (str "TONE 18 " freq " " dur))
            (go (cdr remaining))))))
    (go notes)))

;; ── Setup ──────────────────────────────────────────────

(cmd "WATCH 20 pullup")
(cmd "WATCH 22 pullup")

(define cur 0)
(show-selection cur)

(println "")
(println "=== PICO JUKEBOX ===")
(println "  GP20 = PLAY")
(println "  GP22 = NEXT")
(println "")
(println (str ">> " (nth song-names cur)))

;; ── Loop ───────────────────────────────────────────────

(define (jukebox-loop)
  (let ((resp (cmd "POLL")))
    (for-each
      (fn (ev)
        (when (equal? (get ev :edge) "fall")
          (let ((gpio (get ev :gpio)))
            (cond
              ((= gpio 20) (println (str "   Playing: " (nth song-names cur)))
                (play-song (nth songs cur))
                (leds-off)
                (neo! 0 0 0)
                (sleep 300)
                (show-selection cur)
                (println (str ">> " (nth song-names cur))))
              ((= gpio 22) (set! cur (mod (+ cur 1) num-songs))
                (show-selection cur)
                (println (str ">> " (nth song-names cur)))
                (cmd "TONE 18 400 30"))))))
      (get resp :events)))
  (sleep 50)
  (jukebox-loop))

(jukebox-loop)
