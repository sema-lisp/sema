;; System F — Out of the Blue
;; Extracted from MIDI, played on Pico 2 + Maker Pi Pico
;; Piezo buzzer on GP18, LEDs on GP0-7, NeoPixels on GP28

(define pico (serial/open "/dev/tty.usbmodem1201" 115200 3000))
(define (cmd s) (serial/send pico s))
(try (serial/read-line pico) (catch e nil))
(cmd "PING")

(define (led! pin val) (cmd (str "PIN_SET " pin " " val)))
(define (neo! idx r g b) (cmd (str "NEOPIXEL 3 " idx " " r " " g " " b)))

