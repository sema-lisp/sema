;; Map freq to LED position (0-7) based on octave position
(define (freq->led freq)
  (cond
    ((< freq 100) 0)
    ((< freq 150) 1)
    ((< freq 200) 2)
    ((< freq 250) 3)
    ((< freq 300) 4)
    ((< freq 350) 5)
    ((< freq 400) 6)
    (else 7)))

;; Map freq to NeoPixel color — low=warm, high=cool
(define (freq->color freq)
  (cond
    ((< freq 100) (list 40 0 0)) ; deep red (bass)
    ((< freq 150) (list 80 20 0)) ; orange
    ((< freq 200) (list 60 60 0)) ; yellow
    ((< freq 250) (list 0 80 0)) ; green
    ((< freq 300) (list 0 60 60)) ; cyan
    ((< freq 350) (list 0 20 80)) ; blue
    ((< freq 400) (list 40 0 80)) ; purple
    (else (list 80 0 60)))) ; magenta

(println "♪ System F — Out of the Blue ♪")
(println (str "  " (length song) " notes, ~13 seconds"))
(println "")

;; Play notes with wall-clock timing using time/now
;; This compensates for serial latency — notes hit at the right time
(define song-start (time/now))

(define (elapsed-ms)
  (floor (* (- (time/now) song-start) 1000)))

(define (play-song notes)
  (when (not (null? notes))
    (let ((note (car notes))
          (rest-notes (cdr notes)))
      (let ((target-ms (car note))
            (freq (nth note 1))
            (dur (nth note 2)))
        ;; Wait until the right moment
        (let ((wait (- target-ms (elapsed-ms))))
          (when (> wait 0) (sleep wait)))
        ;; Visuals
        (let ((led-pos (freq->led freq))
              (rgb (freq->color freq)))
          (dotimes (i 8) (led! i 0))
          (led! led-pos 1)
          (neo! 0 (nth rgb 0) (nth rgb 1) (nth rgb 2))
          (neo! 1 (nth rgb 1) (nth rgb 2) (nth rgb 0))
          (neo! 2 (nth rgb 2) (nth rgb 0) (nth rgb 1)))
        ;; Play tone (blocks on Pico for duration)
        (cmd (str "TONE 18 " freq " " dur))
        ;; Next
        (play-song rest-notes)))))

(play-song song)

;; Lights out
(dotimes (i 8) (led! i 0))
(neo! 0 0 0 0)
(neo! 1 0 0 0)
(neo! 2 0 0 0)
(serial/close pico)
(println "♪ Fin ♪")
