;; tui.sema — the full-screen (sema) coder terminal UI.
;;
;; A bespoke, hand-rendered TUI built directly on the host primitives this
;; branch added: alt-screen + cursor control (term/*), raw-mode key input
;; (io/tty-raw!, io/read-key-timeout), terminal size + resize (sys/term-size,
;; sys/on-signal :winch), and streaming agent turns (agent/run :on-text).
;;
;; Rendering model (Mire-inspired): every frame is rebuilt as a list of exactly
;; `*rows*` strings; we diff against the previous frame and rewrite only the rows
;; that changed — so there is no full-screen clear and no flicker. All output
;; goes through one stream (stdout via `print`) so cursor moves and content never
;; interleave out of order.

(load "commands.sema")   ;; brings in theme, config, agent, tools, display, util

;; ── Terminal control as strings (emitted through one stream) ─────────────────

(define ESC "\x1b;")
(define (goto row col) (string-append ESC "[" (number->string row) ";" (number->string col) "H"))
(define CLEAR-LINE (string-append ESC "[2K"))

;; ── Mutable UI state ─────────────────────────────────────────────────────────

(define *rows* 24)
(define *cols* 80)
(define *cwd* ".")
(define *model* "")
(define *agent* #f)
(define *config* {})
(define *messages* '())
(define *transcript* '())   ;; list of blocks, oldest → newest
(define *input* "")
(define *cursor* 0)         ;; caret index into *input*
(define *scroll* 0)         ;; lines scrolled up from the bottom (0 = follow tail)
(define *psel* 0)           ;; selected index in the slash palette
(define *phase* :idle)      ;; :idle | :thinking
(define *in-tok* 0)
(define *out-tok* 0)
(define *interrupt* #f)
(define *should-quit* #f)
(define *last-frame* '())   ;; previous frame's rows, for diffing

;; ── Block constructors + transcript mutation ─────────────────────────────────

(define (add-block! b) (set! *transcript* (append *transcript* (list b))) (set! *scroll* 0))

(define (kind? b k) (equal? (get b :kind :none) k))

(define (update-last! f)
  (let ((n (length *transcript*)))
    (when (> n 0)
      (set! *transcript*
        (append (take (- n 1) *transcript*)
                (list (f (nth *transcript* (- n 1)))))))))

(define (last-block) (let ((n (length *transcript*))) (if (> n 0) (nth *transcript* (- n 1)) #f)))

(define (append-assistant! delta)
  (let ((lb (last-block)))
    (if (and lb (kind? lb :assistant))
      (update-last! (lambda (b) (assoc b :text (string-append (:text b) delta))))
      (add-block! {:kind :assistant :text delta}))))

(define (set-last-tool-done! ms)
  (update-last! (lambda (b) (assoc (assoc b :state :done) :ms ms))))

;; ── Small helpers ────────────────────────────────────────────────────────────

(define (vis-width s) (string/width s))    ;; display columns, ignoring ANSI + wide-char aware

(define (pad-to s w)
  "Pad a (possibly styled) string with spaces to visible width W (no truncation)."
  (let ((n (vis-width s)))
    (if (< n w) (string-append s (string/repeat " " (- w n))) s)))

(define (clamp-plain s w)
  "Truncate PLAIN text to width W, adding an ellipsis when cut."
  (if (<= (string-length s) w) s
    (if (<= w 1) (string/slice s 0 w)
      (string-append (string/slice s 0 (- w 1)) "…"))))

;; ── Text wrapping ────────────────────────────────────────────────────────────
;; Delegates to the native, display-width-aware string/wrap (correct for CJK /
;; emoji / combining marks, which a char-count wrap gets wrong).

(define (wrap-text text w) (string/word-wrap text w))

;; ── Transcript → styled lines (each fits within *cols*, 1-space left margin) ──

(define (indent line) (string-append " " line))

(define (block-lines b w)
  "Render one transcript block to a list of styled lines (content width W)."
  (cond
    ((kind? b :user)
      (append
        (map (lambda (i-l)
               (let ((i (nth i-l 0)) (l (nth i-l 1)))
                 (if (= i 0)
                   (indent (string-append (accent (string-append user-glyph " ")) (bright l)))
                   (indent (string-append "  " (bright l))))))
             (enumerate (wrap-text (:text b) (- w 2))))
        (list "")))
    ((kind? b :assistant)
      ;; An empty assistant block (the pre-first-token streaming target, or a
      ;; post-tool round with no text) renders nothing.
      (if (= (string/trim (:text b)) "") '()
        (append (map (lambda (l) (indent l)) (wrap-text (:text b) w)) (list ""))))
    ((kind? b :tool)
      (let* ((tool (:tool b)) (arg (clamp-plain (get b :arg "") (max 4 (- w 18)))))
        (if (equal? (get b :state :done) :running)
          (list (indent (string-append (faint "·") " "
                                        (accent-dim (term/style tool :bold)) " " (muted arg))))
          (list (indent (string-append (ok "✔") " "
                                        (accent-dim (term/style tool :bold)) " " (muted arg)
                                        " " (faint (string-append (number->string (get b :ms 0)) "ms"))))))))
    ((kind? b :info)  (map (lambda (l) (indent (muted l))) (wrap-text (:text b) w)))
    ((kind? b :error) (map (lambda (l) (indent (bad l))) (wrap-text (string-append "error: " (:text b)) w)))
    (else '())))

(define (enumerate xs)
  (let loop ((i 0) (rest xs) (out '()))
    (if (null? rest) (reverse out)
      (loop (+ i 1) (cdr rest) (cons (cons i (car rest)) out)))))

(define (transcript-lines w)
  (apply append (map (lambda (b) (block-lines b w)) *transcript*)))

;; ── Palette (slash-command popup) ────────────────────────────────────────────

(define (palette-open?) (string/starts-with? *input* "/"))

(define (palette-query)
  (let* ((rest (string/slice *input* 1 (string-length *input*)))
         (sp   (string/index-of rest " ")))
    (if sp (string/slice rest 0 sp) rest)))

(define (all-command-entries)
  "Every command as {:name :desc}: built-in registry order + config-defined."
  (append
    (map (lambda (n) {:name n :desc (get (get *commands* n {}) :desc "")}) *command-order*)
    (map (lambda (k) {:name (keyword->string k)
                      :desc (get (get *config* :commands {}) k "")})
         (keys (get *config* :commands {})))))

(define (fuzzy-score query item)
  "Subsequence score (case-insensitive); #f if QUERY isn't a subsequence of ITEM."
  (if (= query "") 0
    (let ((q (string/lower query)) (it (string/lower item)))
      (let loop ((qi 0) (ii 0) (score 0) (streak 0))
        (cond
          ((>= qi (string-length q)) score)
          ((>= ii (string-length it)) #f)
          ((equal? (string/slice q qi (+ qi 1)) (string/slice it ii (+ ii 1)))
            (loop (+ qi 1) (+ ii 1) (+ score (+ 1 streak) (if (= ii 0) 3 0)) (+ streak 1)))
          (else (loop qi (+ ii 1) score 0)))))))

(define (palette-matches)
  ;; Score every command, drop non-matches, best-first, then unwrap to entries.
  (let ((q (palette-query)))
    (->> (all-command-entries)
         (map (lambda (e) (list (fuzzy-score q (:name e)) e)))
         (filter (lambda (pair) (nth pair 0)))
         (sort-by (lambda (pair) (- (nth pair 0))))
         (map (lambda (pair) (nth pair 1))))))

(define (fit-plain s n)
  "Pad or truncate PLAIN text to exactly width N."
  (let ((len (string-length s)))
    (cond ((= len n) s)
          ((< len n) (string-append s (string/repeat " " (- n len))))
          (else (clamp-plain s n)))))

(define (palette-box matches sel bw)
  "Render the slash palette as a bordered box of outer width BW: gold parens/label,
   faint borders, the selected row in accent. Returns a list of styled lines."
  (let* ((shown (take (min 8 (length matches)) matches))
         (inner (max 8 (- bw 4)))                 ;; text width inside │ … │
         (label " commands ")
         (top (string-append (faint "┌") (accent-dim label)
                             (faint (string-append (string/repeat "─" (max 0 (- bw 2 (string-length label)))) "┐"))))
         (bot (faint (string-append "└" (string/repeat "─" (max 0 (- bw 2))) "┘")))
         (rows (enumerate-map
                 (lambda (i e)
                   (let* ((sel?  (= i sel))
                          (nm    (string/pad-right (string-append "/" (:name e)) 12))
                          (dw    (max 4 (- inner 15)))
                          (txt   (fit-plain (string-append (if sel? "▸ " "  ") nm " "
                                                           (clamp-plain (:desc e) dw)) inner))
                          (body  (if sel? (accent txt) (muted txt))))
                     (string-append (faint "│ ") body (faint " │"))))
                 shown)))
    (map (lambda (l) (indent l)) (append (list top) rows (list bot)))))

(define (enumerate-map f xs)
  (let loop ((i 0) (rest xs) (out '()))
    (if (null? rest) (reverse out)
      (loop (+ i 1) (cdr rest) (cons (f i (car rest)) out)))))

;; ── Frame assembly ───────────────────────────────────────────────────────────

(define (transcript-height) (max 1 (- *rows* 3)))

(define (header-line)
  (let* ((left  (string-append " " (wordmark-with "coder")))
         (right (muted (format "~a · ↑~a ↓~a"
                        (if (= *model* "") "auto" *model*) *in-tok* *out-tok*)))
         (gap   (max 1 (- *cols* (vis-width left) (vis-width right) 1))))
    (string-append left (string/repeat " " gap) right)))

(define (status-line)
  ;; Deliberately minimal: no spinner, no keyboard-shortcut clutter. Only a
  ;; scroll-position indicator when the user has scrolled up off the tail.
  (indent (faint (if (> *scroll* 0) (format "↕ scrolled +~a" *scroll*) ""))))

(define (prompt-line)
  ;; Show the tail of a long input so the caret stays on screen.
  (let* ((avail (max 4 (- *cols* 4)))
         (shown (if (<= (string-length *input*) avail) *input*
                  (string/slice *input* (- (string-length *input*) avail) (string-length *input*)))))
    (indent (string-append (accent (string-append prompt-glyph " ")) shown))))

(define (prompt-cursor-col) (+ 1 1 2 *cursor*))  ;; margin(1)+glyph"❯ "(2)+... 1-based

(define (viewport lines h)
  "Take the last H lines, honoring *scroll* (0 = bottom). Pad with blanks on top."
  (let* ((n (length lines))
         (maxscroll (max 0 (- n h)))
         (sc (min *scroll* maxscroll))
         (end (- n sc))
         (start (max 0 (- end h)))
         (window (if (> n 0) (take (- end start) (drop start lines)) '()))
         (pad (- h (length window))))
    (if (> pad 0) (append (make-list pad "") window) window)))

(define (make-list n v) (if (<= n 0) '() (cons v (make-list (- n 1) v))))

(define (overlay-bottom base over)
  "Replace the last (length OVER) rows of BASE with OVER."
  (let* ((n (length base)) (k (min (length over) n)))
    (append (take (- n k) base) (drop (- (length over) k) over))))

(define (build-frame)
  ;; Content width leaves 1 char of padding on BOTH sides (indent adds the left
  ;; space; wrapping to *cols*-2 leaves the right gap) so text feels less cramped.
  (let* ((h (transcript-height))
         (tlines (viewport (transcript-lines (- *cols* 2)) h))
         (body (if (palette-open?)
                 (overlay-bottom tlines (palette-box (palette-matches) *psel* (- *cols* 3)))
                 tlines))
         (rows (append (list (header-line)) body (list (prompt-line)) (list (status-line)))))
    ;; Normalize to exactly *rows* padded strings.
    (map (lambda (s) (pad-to s *cols*)) (fit-rows rows *rows*))))

(define (fit-rows rows n)
  (let ((have (length rows)))
    (cond ((= have n) rows)
          ((> have n) (take n rows))
          (else (append rows (make-list (- n have) ""))))))

;; ── Diff render ──────────────────────────────────────────────────────────────

(define (frame-ref f i) (if (< i (length f)) (nth f i) ""))

(define (render!)
  (let ((frame (build-frame)) (out ""))
    (let loop ((i 0))
      (when (< i *rows*)
        (let ((new (frame-ref frame i)) (old (frame-ref *last-frame* i)))
          (unless (equal? new old)
            (set! out (string-append out (goto (+ i 1) 1) CLEAR-LINE new))))
        (loop (+ i 1))))
    ;; Park the hardware cursor at the prompt caret.
    (set! out (string-append out (goto (- *rows* 1) (prompt-cursor-col))))
    (display out)   ;; display writes the raw string; print would add quotes
    (io/flush)
    (set! *last-frame* frame)))

(define (full-repaint!) (set! *last-frame* '()) (render!))

;; ── Interrupt polling (raw mode: Ctrl-C is a byte, not a signal) ─────────────

(define (poll-interrupt!)
  (let ((k (io/read-key-timeout 0)))
    (when (and k (equal? (:kind k) :ctrl) (equal? (:char k) "c"))
      (set! *interrupt* #t)
      (error "interrupted"))))

;; ── Streaming callbacks ──────────────────────────────────────────────────────

(define (on-text-cb delta)
  (poll-interrupt!)
  (when (> (string-length delta) 0) (append-assistant! delta))
  (render!))

(define (on-tool-cb event)
  (poll-interrupt!)
  (let ((evt (:event event)) (tool (:tool event)) (args (:args event)))
    (cond
      ((= evt "start")
        (let ((arg (tool-arg tool (if (map? args) args {}))))
          (add-block! {:kind :tool :tool tool :arg arg :state :running :ms 0})))
      ((= evt "end")
        (set-last-tool-done! (get event :duration-ms 0))
        (add-block! {:kind :assistant :text ""}))))   ;; target for post-tool text
  (render!))

;; ── Running a turn ───────────────────────────────────────────────────────────

(define (run-agent-turn! text)
  (set! *interrupt* #f)
  ;; The empty assistant block is the streaming target; while *phase* is
  ;; :thinking it renders a quiet "…" placeholder until the first token lands.
  (add-block! {:kind :assistant :text ""})
  (render!)
  (let ((result
          (try
            (run-turn-streaming *agent* text *messages* on-tool-cb on-text-cb)
            (catch e
              (if *interrupt*
                (begin (add-block! {:kind :info :text "interrupted"}) #f)
                (begin (add-block! {:kind :error :text (format "~a" e)}) #f))))))
    (when result
      (set! *messages* (:messages result))
      (let ((u (llm/last-usage)))
        (when (map? u)
          (set! *in-tok*  (+ *in-tok*  (get u :prompt-tokens 0)))
          (set! *out-tok* (+ *out-tok* (get u :completion-tokens 0))))))))

;; ── Commands (TUI-native: output goes to the transcript, not the screen) ─────

(define (run-command! input)
  (let* ((cmd (parse-command input)) (name (:name cmd)) (args (:args cmd))
         (shell-tmpl (user-command *config* name)))
    (cond
      ((member name (list "quit" "exit")) (set! *should-quit* #t))
      ((= name "help")  (cmd-help))
      ((= name "clear") (set! *messages* '()) (set! *transcript* '())
                        (add-block! {:kind :info :text "conversation cleared"}))
      ((= name "model") (cmd-model args))
      ((= name "tools") (for-each (lambda (n) (add-block! {:kind :info :text n})) tool-names))
      ((= name "cwd")   (add-block! {:kind :info :text *cwd*}))
      ((= name "config")(add-block! {:kind :info :text (format "config: ~a" (config-path))}))
      ((= name "reload")(let ((cfg (load-config)))
                          (set! *config* cfg)
                          (set! *agent* (create-agent *cwd* *model* cfg))
                          (add-block! {:kind :info :text "config reloaded"})))
      (shell-tmpl (cmd-shell shell-tmpl args))
      (else (add-block! {:kind :error :text (format "unknown command: /~a (try /help)" name)})))))

(define (cmd-help)
  (add-block! {:kind :info :text "commands:"})
  (for-each
    (lambda (e) (add-block! {:kind :info :text (format "  /~a — ~a" (:name e) (:desc e))}))
    (all-command-entries)))

(define (cmd-model args)
  (if (= args "")
    (add-block! {:kind :info :text (format "model: ~a" (if (= *model* "") "auto" *model*))})
    (begin
      (set! *model* args)
      (set! *agent* (create-agent *cwd* args *config*))
      (add-block! {:kind :info :text (format "switched to ~a" args)}))))

(define (cmd-shell template args)
  (let* ((cmd (string/replace template "$ARGS" args))
         (res (run-in-workspace cmd))
         (out (string/trim (:stdout res)))
         (err (string/trim (:stderr res))))
    (add-block! {:kind :info :text (string-append "$ " cmd)})
    (when (not (= out "")) (add-block! {:kind :assistant :text out}))
    (when (not (= err "")) (add-block! {:kind :error :text err}))))

;; ── Key handling ─────────────────────────────────────────────────────────────

(define (insert-char! ch)
  (set! *input* (string-append (string/slice *input* 0 *cursor*) ch
                               (string/slice *input* *cursor* (string-length *input*))))
  (set! *cursor* (+ *cursor* (string-length ch)))
  (set! *psel* 0))

(define (backspace!)
  (when (> *cursor* 0)
    (set! *input* (string-append (string/slice *input* 0 (- *cursor* 1))
                                 (string/slice *input* *cursor* (string-length *input*))))
    (set! *cursor* (- *cursor* 1))
    (set! *psel* 0)))

(define (clear-input!) (set! *input* "") (set! *cursor* 0) (set! *psel* 0))

(define (on-enter)
  (let ((text (string/trim *input*)))
    (cond
      ((= text "") nil)
      ((palette-open?)
        (let* ((matches (palette-matches))
               (parsed  (parse-command *input*))
               ;; If the typed name is itself a command, run it; else run the selection.
               (known?  (or (get *commands* (:name parsed) #f) (user-command *config* (:name parsed))))
               (chosen  (cond (known? *input*)
                              ((> (length matches) 0)
                               (string-append "/" (:name (nth matches (min *psel* (- (length matches) 1))))
                                              (if (= (:args parsed) "") "" (string-append " " (:args parsed)))))
                              (else *input*))))
          (clear-input!)
          (run-command! chosen)))
      (else
        (add-block! {:kind :user :text text})
        (clear-input!)
        (set! *phase* :thinking)
        (run-agent-turn! text)
        (set! *phase* :idle)
        (render!)))))

(define (handle-ctrl ch)
  (cond
    ((= ch "c") (if (> (string-length *input*) 0) (clear-input!) (set! *should-quit* #t)))
    ((= ch "d") (set! *should-quit* #t))
    ((= ch "k") (set! *input* "/") (set! *cursor* 1) (set! *psel* 0))
    ((= ch "u") (clear-input!))
    ((= ch "a") (set! *cursor* 0))
    ((= ch "e") (set! *cursor* (string-length *input*)))
    ((= ch "l") (full-repaint!))
    (else nil)))

(define (handle-named name)
  (cond
    ((equal? name :enter)     (on-enter))
    ((equal? name :backspace) (backspace!))
    ((equal? name :left)      (set! *cursor* (max 0 (- *cursor* 1))))
    ((equal? name :right)     (set! *cursor* (min (string-length *input*) (+ *cursor* 1))))
    ((equal? name :home)      (set! *cursor* 0))
    ((equal? name :end)       (set! *cursor* (string-length *input*)))
    ((equal? name :tab)
      (when (palette-open?)
        (let ((matches (palette-matches)))
          (when (> (length matches) 0)
            (set! *input* (string-append "/" (:name (nth matches (min *psel* (- (length matches) 1)))) " "))
            (set! *cursor* (string-length *input*))))))
    ((equal? name :up)
      (if (palette-open?) (set! *psel* (max 0 (- *psel* 1)))
        (set! *scroll* (+ *scroll* 1))))
    ((equal? name :down)
      (if (palette-open?)
        (set! *psel* (+ *psel* 1))
        (set! *scroll* (max 0 (- *scroll* 1)))))
    ((equal? name :page-up)   (set! *scroll* (+ *scroll* (transcript-height))))
    ((equal? name :page-down) (set! *scroll* (max 0 (- *scroll* (transcript-height)))))
    ((equal? name :esc)       (when (palette-open?) (clear-input!)))
    (else nil)))

(define (handle-mouse k)
  ;; Wheel scrolls the transcript; other mouse events are ignored for now.
  (let ((action (:action k)))
    (cond
      ((equal? action :wheel-up)   (set! *scroll* (+ *scroll* 3)))
      ((equal? action :wheel-down) (set! *scroll* (max 0 (- *scroll* 3))))
      (else nil))))

(define (handle-key k)
  (let ((kind (:kind k)))
    (cond
      ((equal? kind :ctrl)  (handle-ctrl (:char k)))
      ((equal? kind :key)   (handle-named (:name k)))
      ((equal? kind :char)  (insert-char! (:char k)))
      ((equal? kind :mouse) (handle-mouse k))
      (else nil))))

;; ── Resize ───────────────────────────────────────────────────────────────────

(define *resize-pending* #t)

(define (recompute-size!)
  (let ((sz (sys/term-size)))
    (when (map? sz)
      (set! *rows* (max 6 (:rows sz)))
      (set! *cols* (max 20 (:cols sz)))))
  (set! *resize-pending* #f))

(define (check-resize!)
  (sys/check-signals)
  (when *resize-pending* (recompute-size!) (full-repaint!)))

;; ── Entry point ──────────────────────────────────────────────────────────────

(define (tui-run cwd model cfg agent)
  (set! *cwd* cwd) (set! *model* model) (set! *config* cfg) (set! *agent* agent)
  (recompute-size!)
  (sys/on-signal :winch (lambda () (set! *resize-pending* #t)))
  ;; The guards restore raw mode, the alt screen, the cursor, and mouse reporting
  ;; on ANY exit — normal or via a thrown error — so a crash can't leave the
  ;; terminal broken. (mouse wheel scrolls the transcript → {:kind :mouse}.)
  (io/with-raw-mode
    (term/with-alt-screen
      (term/with-mouse
        (term/set-title "(sema) coder")
        (add-block! {:kind :info :text (format "(sema) coder — ~a · ~a" cwd (if (= model "") "auto" model))})
        (add-block! {:kind :info :text "type / for commands, ⌃K for the palette, ⌃D to quit"})
        (full-repaint!)
        (let loop ()
          (check-resize!)
          (let ((k (io/read-key-timeout 250)))
            (when k (handle-key k) (render!)))
          (unless *should-quit* (loop))))))
  (io/flush))
