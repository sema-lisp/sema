;; Modal styles
(def overlay-style
  (css {:position "fixed"
        :top "0" :left "0" :right "0" :bottom "0"
        :background "rgba(0,0,0,0.5)"
        :display "flex"
        :align-items "flex-start"
        :justify-content "center"
        :padding-top "80px"
        :z-index "1000"}))

(def modal-style
  (css {:background "#fff"
        :border-radius "12px"
        :padding "24px"
        :width "520px"
        :max-width "90vw"
        :max-height "80vh"
        :overflow-y "auto"
        :box-shadow "0 12px 48px rgba(0,0,0,0.25)"}))

(def modal-title-style
  (css {:font-size "20px"
        :font-weight "700"
        :color "#172b4d"
        :margin-bottom "4px"
        :line-height "1.3"}))

(def modal-section-label-style
  (css {:font-size "12px"
        :font-weight "600"
        :color "#5e6c84"
        :text-transform "uppercase"
        :margin-top "16px"
        :margin-bottom "6px"
        :letter-spacing "0.04em"}))

(def modal-desc-style
  (css {:width "100%"
        :min-height "80px"
        :padding "10px"
        :border "1px solid #dfe1e6"
        :border-radius "6px"
        :font-size "14px"
        :color "#172b4d"
        :outline "none"
        :resize "vertical"
        :font-family "inherit"
        "&:focus" {:border-color "#0079bf"}}))

(def modal-row-style
  (css {:display "flex"
        :align-items "center"
        :gap "8px"
        :margin-top "8px"}))

(def modal-btn-style
  (css {:padding "6px 14px"
        :border "1px solid #dfe1e6"
        :border-radius "4px"
        :font-size "13px"
        :cursor "pointer"
        :background "#fff"
        :color "#172b4d"
        "&:hover" {:background "#f4f5f7"}}))

(def modal-close-style
  (css {:padding "8px 20px"
        :background "#091e420a"
        :border "none"
        :border-radius "4px"
        :font-size "14px"
        :cursor "pointer"
        :color "#172b4d"
        :margin-top "20px"
        "&:hover" {:background "#091e4214"}}))

(def modal-col-badge-style
  (css {:font-size "13px"
        :color "#0079bf"
        :font-weight "600"}))

;; ── Render Components ───────────────────────────────────────────────

(define (priority-badge prio)
  (let ((cls (cond
               ((equal? prio "low") prio-low)
               ((equal? prio "medium") prio-medium)
               ((equal? prio "high") prio-high)
               ((equal? prio "urgent") prio-urgent)
               (#t prio-medium))))
    [:span {:class (string-append prio-badge-style " " cls)
            :data-testid "priority-badge"} prio]))

(define (col-display-name col)
  (cond ((equal? col "todo") "To Do")
        ((equal? col "in-progress") "In Progress")
        ((equal? col "done") "Done")
        (#t col)))

(define (render-card card)
  (let ((id (get card :id))
        (title (get card :title))
        (desc (get card :description))
        (prio (get card :priority))
        (col (get card :column))
        (ai (get card :ai-generated))
        (created (get card :created-at)))
    (let ((is-dragging (equal? @drag-card-id id)))
    [:div {:class (if is-dragging card-dragging-style card-style)
           :data-testid "board-card"
           :data-card-id (->str id)
           :on-pointerdown "handle-pointer-down-card"
           :on-click "handle-card-click"}
      [:div {:class card-title-style :data-testid "card-title"} title]
      (when (not (equal? desc ""))
        [:div {:class card-desc-preview-style} desc])
      [:div {:class card-meta-style}
        (priority-badge prio)
        (when ai [:span {:class ai-tag-style :data-testid "ai-badge"} "AI"])
        [:span {:class timer-style}
          "\u23F1 "
          ;; Force re-render every tick
          (begin @tick (format-elapsed (- @tick created)))]]
      [:div {:class card-actions-style}
        (when (not (equal? col "todo"))
          [:button {:class action-btn-style
                    :data-card-id (->str id)
                    :on-click "handle-move-left"
                    :data-testid "move-left-btn"
                    :title "Move left"} "\u2190"])
        (when (not (equal? col "done"))
          [:button {:class action-btn-style
                    :data-card-id (->str id)
                    :on-click "handle-move-right"
                    :data-testid "move-right-btn"
                    :title "Move right"} "\u2192"])
        [:button {:class delete-btn-style
                  :data-card-id (->str id)
                  :on-click "handle-delete"
                  :data-testid "delete-btn"
                  :title "Delete"} "\u2717"]]])))

(define (render-add-form col)
  (if (equal? @adding-col col)
    [:div {:class add-form-style :data-testid "add-card-form"}
      [:input {:class add-input-style
               :placeholder "Enter a title for this card..."
               :value @adding-text
               :on-input "handle-add-input"
               :on-keydown "handle-add-keydown"
               :autocomplete "off"
               :data-testid "add-card-input"
               :id "add-card-input"}]
      [:div {:class add-actions-style}
        [:button {:class add-submit-style
                  :on-click "submit-add-card"
                  :data-testid "submit-add-card"} "Add Card"]
        [:button {:class add-cancel-style
                  :on-click "cancel-add-card"} "\u00D7"]]]
    [:button {:class add-btn-style
              :on-click (cond
                          ((equal? col "todo") "start-add-todo")
                          ((equal? col "in-progress") "start-add-progress")
                          (#t "start-add-done"))
              :data-testid (string-append "add-card-" col)}
      "+ Add a card"]))

(define (render-column col-id col-name)
  (let ((cards (filtered-cards-for col-id))
        (is-drag-target (equal? @drag-over-col col-id)))
    [:div {:class (if is-drag-target column-drag-over-style column-style)
           :data-testid (string-append "column-" col-id)
           :data-col-id col-id
           :on-pointermove "handle-pointer-move-col"
           :on-pointerup "handle-pointer-up-col"}
      [:div {:class col-header-style}
        [:span {:class col-title-style} col-name]
        [:span {:class col-count-style :data-testid (string-append "count-" col-id)}
          (->str (length cards))]]
      [:div {:class cards-list-style}
        (if (null? cards)
          [:div {:class empty-col-msg-style} "No cards yet"]
          (map render-card cards))]
      (render-add-form col-id)]))

(define (render-header)
  [:div {:class header-style :data-testid "board-header"}
    [:span {:class header-title-style} "\u2630 Project Board"]
    [:div {:class header-right-style}
      [:div {:class search-wrap-style}
        [:span {:class search-icon-style} "\u2315"]
        [:input {:class search-input-style
                 :type "text"
                 :placeholder "Search cards..."
                 :value @search-text
                 :on-input "handle-search"
                 :data-testid "search-input"
                 :id "search-input"}]
        (when @search-active
          [:button {:class clear-search-btn-style
                    :on-click "clear-search"
                    :data-testid "clear-search"} "\u00D7"])]
      [:div {:class progress-wrap-style :data-testid "progress-text"}
        [:div {:class progress-bar-bg-style}
          [:div {:class progress-bar-fill-style
                 :style (string-append "width:" (->str @progress-pct) "%")
                 :data-testid "progress-fill"}]]
        [:span (string-append (->str @done-count) "/" (->str @total-count))]]
      (if @ai-loading
        [:button {:class ai-btn-loading-style :disabled "true"
                  :data-testid "ai-generate-btn"} "Generating..."]
        [:button {:class ai-btn-style
                  :on-click "ai-generate-tasks"
                  :data-testid "ai-generate-btn"} "\u2728 AI Generate"])]])

;; ── Modal (detail view, mounted separately) ─────────────────────────

(define (modal-view)
  (if-let (id @selected-card-id)
    (if-let (card (find-card-by-id @board id))
      [:div {:class overlay-style :on-click "close-modal" :data-testid "card-modal"}
        [:div {:class modal-style :on-click "stop-propagation"}
          [:div {:class modal-title-style :data-testid "modal-title"} (get card :title)]
          [:div {:class modal-section-label-style} "Column"]
          [:div {:class modal-row-style}
            [:span {:class modal-col-badge-style} (col-display-name (get card :column))]
            [:button {:class modal-btn-style :on-click "handle-modal-move-left"
                      :data-testid "modal-move-left"} "\u2190 Move Left"]
            [:button {:class modal-btn-style :on-click "handle-modal-move-right"
                      :data-testid "modal-move-right"} "Move Right \u2192"]]
          [:div {:class modal-section-label-style} "Priority"]
          [:div {:class modal-row-style}
            (priority-badge (get card :priority))
            [:button {:class modal-btn-style :on-click "handle-cycle-priority"
                      :data-testid "cycle-priority"} "Cycle Priority"]]
          [:div {:class modal-section-label-style} "Description"]
          [:textarea {:class modal-desc-style
                      :value (get card :description)
                      :on-input "handle-modal-desc"
                      :placeholder "Add a more detailed description..."
                      :data-testid "modal-description"}]
          [:div {:class modal-section-label-style} "Time in Column"]
          [:div {:style "font-size:13px;color:#5e6c84"}
            (begin @tick (format-elapsed (- @tick (get card :created-at))))]
          (when (get card :ai-generated)
            [:div {:style "margin-top:12px"}
              [:span {:class ai-tag-style} "AI Generated"]])
          [:button {:class modal-close-style :on-click "close-modal"
                    :data-testid "modal-close"} "Close"]]]
      [:span])
    [:span]))

(define (stop-propagation ev)
  (dom/stop-propagation! ev))

;; ── Board Root (main mount point) ───────────────────────────────────

(define (board-root)
  [:div {:style "display:flex;flex-direction:column;height:100vh"
         :on-keydown "handle-global-keydown"}
    (render-header)
    [:div {:class board-style :data-testid "board-columns"}
      (render-column "todo" "To Do")
      (render-column "in-progress" "In Progress")
      (render-column "done" "Done")]
    (render-ai-status)
    ;; Modal overlay (rendered inline — separate mount doesn't track state changes)
    (modal-view)])

;; ── Mount ───────────────────────────────────────────────────────────

(mount! "#app" board-root)
