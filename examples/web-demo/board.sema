;; Trello-style AI Project Board — Sema Web flagship demo
;; Showcases ALL sema-web features: reactive state, computed values,
;; scoped CSS, SIP markup, event handling, LLM streaming, localStorage,
;; DOM manipulation, timers, multiple mount points, batch updates.

;; ── Reactive State ──────────────────────────────────────────────────

(def next-id (state 100))
(def board (state (list)))
(def search-text (state ""))
(def drag-card-id (state nil))
(def drag-source-col (state nil))
(def drag-over-col (state nil))
(def selected-card-id (state nil))
(def tick (state 0))
(def ai-stream (state nil))
(def ai-loading (state #f))
(def adding-col (state nil))
(def adding-text (state ""))

;; ── Computed State ──────────────────────────────────────────────────

(def total-count (computed (length @board)))
(def done-count (computed (length (filter (fn (c) (equal? (get c :column) "done")) @board))))
(def progress-pct (computed
  (let ((t @total-count)
        (d @done-count))
    (if (or (null? t) (null? d) (= t 0)) 0
      (/ (* d 100) t)))))
(def search-active (computed (not (equal? @search-text ""))))

;; ── ID Generation ───────────────────────────────────────────────────

(define (gen-id)
  (let ((id @next-id))
    (update! next-id (fn (n) (+ n 1)))
    (number->string id)))

;; ── Seed Data ───────────────────────────────────────────────────────

(define (make-seed-data)
  (list
    {:id "1" :title "Set up CI/CD pipeline"
     :description "Configure GitHub Actions for automated testing and deployment"
     :column "todo" :priority "high" :created-at 0 :ai-generated #f}
    {:id "2" :title "Design landing page mockup"
     :description "Create wireframes in Figma for the new marketing site"
     :column "todo" :priority "medium" :created-at 0 :ai-generated #f}
    {:id "3" :title "Implement user authentication"
     :description "Add OAuth2 login with Google and GitHub providers"
     :column "in-progress" :priority "urgent" :created-at 0 :ai-generated #f}
    {:id "4" :title "Write API documentation"
     :description "Document all REST endpoints with examples"
     :column "in-progress" :priority "medium" :created-at 0 :ai-generated #f}
    {:id "5" :title "Fix responsive layout on mobile"
     :description "Header nav collapses incorrectly below 768px"
     :column "done" :priority "high" :created-at 0 :ai-generated #f}
    {:id "6" :title "Add unit tests for auth module"
     :description "Cover login, signup, and token refresh flows"
     :column "todo" :priority "low" :created-at 0 :ai-generated #f}))

;; ── Persistence ─────────────────────────────────────────────────────

(define (save-board)
  (store/set! "sema-board-data" @board)
  (store/set! "sema-board-next-id" @next-id))

(define (load-board)
  (let ((saved (store/get "sema-board-data"))
        (saved-id (store/get "sema-board-next-id")))
    (if (not (null? saved))
      (begin
        (put! board saved)
        (when (not (null? saved-id))
          (put! next-id saved-id)))
      (put! board (make-seed-data)))))

(load-board)

;; Auto-save on any board change
(define (on-board-change old new) (save-board))
(watch board "on-board-change")

;; Safe string conversion — handles numbers, strings, and nil
(define (->str x)
  (cond ((null? x) "0")
        ((string? x) x)
        (#t (number->string x))))

;; ── Timer (1s tick for "time in column") ────────────────────────────

(define (tick-clock)
  (update! tick (fn (n) (+ n 1))))

(js/set-interval "tick-clock" 1000)

(define (format-elapsed secs)
  (cond
    ((< secs 60)
     (string-append (number->string secs) "s"))
    ((< secs 3600)
     (string-append (number->string (/ (- secs (modulo secs 60)) 60)) "m"))
    (#t
     (let ((h (/ (- secs (modulo secs 3600)) 3600))
           (m (/ (- (modulo secs 3600) (modulo (modulo secs 3600) 60)) 60)))
       (string-append (number->string h) "h " (number->string m) "m")))))

;; ── Board Helpers ───────────────────────────────────────────────────

(define (find-card-by-id cards id)
  (cond
    ((null? cards) nil)
    ((equal? (get (car cards) :id) id) (car cards))
    (#t (find-card-by-id (cdr cards) id))))

(define (cards-in-col col)
  (filter (fn (c) (equal? (get c :column) col)) @board))

(define (filtered-cards-for col)
  (let ((cards (cards-in-col col))
        (query (string/lower @search-text)))
    (if (equal? query "")
      cards
      (filter (fn (c) (string/contains? (string/lower (get c :title)) query)) cards))))

(define (col-count col)
  (length (filtered-cards-for col)))

(define (next-col col)
  (cond ((equal? col "todo") "in-progress")
        ((equal? col "in-progress") "done")
        (#t nil)))

(define (prev-col col)
  (cond ((equal? col "done") "in-progress")
        ((equal? col "in-progress") "todo")
        (#t nil)))

;; ── Board Mutations ─────────────────────────────────────────────────

(define (add-card col title)
  (when (not (equal? title ""))
    (let ((card {:id (gen-id) :title title :description ""
                 :column col :priority "medium"
                 :created-at @tick :ai-generated #f}))
      (update! board (fn (b) (append b (list card)))))))

(define (delete-card id)
  (update! board (fn (b) (filter (fn (c) (not (equal? (get c :id) id))) b)))
  (when (equal? @selected-card-id id)
    (put! selected-card-id nil)))

(define (move-card id new-col)
  (update! board (fn (b)
    (map (fn (c)
      (if (equal? (get c :id) id)
        (assoc (assoc c :column new-col) :created-at @tick)
        c)) b))))

(define (update-card-field id field val)
  (update! board (fn (b)
    (map (fn (c)
      (if (equal? (get c :id) id)
        (assoc c field val)
        c)) b))))

;; ── Drag and Drop ───────────────────────────────────────────────────

(define (get-card-id-from-event ev)
  (if-let (el (dom/event-target-closest ev "[data-card-id]"))
    ;; Force to string — WASM bridge may auto-convert "1" to 1
    (->str (dom/get-attribute el "data-card-id"))
    nil))

(define (get-col-id-from-event ev)
  (if-let (el (dom/event-target-closest ev "[data-col-id]"))
    (dom/get-attribute el "data-col-id")
    nil))

;; Drag and drop via pointer events
(define (clear-drag-state)
  (put! drag-card-id nil)
  (put! drag-source-col nil)
  (put! drag-over-col nil))

(define (handle-pointer-down-card ev)
  (when-let (card-id-str (get-card-id-from-event ev))
    (when-let (card (find-card-by-id @board card-id-str))
      (put! drag-card-id card-id-str)
      (put! drag-source-col (get card :column)))))

(define (handle-pointer-move-col ev)
  (when (not (null? @drag-card-id))
    (when-let (col-id (get-col-id-from-event ev))
      (put! drag-over-col col-id))))

(define (handle-pointer-up-col ev)
  (when (not (null? @drag-card-id))
    (when-let (target-col (get-col-id-from-event ev))
      (when (not (equal? target-col @drag-source-col))
        (move-card @drag-card-id target-col))))
  (clear-drag-state))

;; ── Event Handlers ──────────────────────────────────────────────────

(define (handle-search ev)
  (put! search-text (dom/event-value ev)))

(define (clear-search ev)
  (put! search-text ""))

(define (handle-card-click ev)
  (when-let (card-id-str (get-card-id-from-event ev))
    (put! selected-card-id card-id-str)))

(define (handle-move-left ev)
  (dom/stop-propagation! ev)
  (dom/prevent-default! ev)
  (when-let (card-id-str (get-card-id-from-event ev))
    (when-let (card (find-card-by-id @board card-id-str))
      (when-let (p (prev-col (get card :column)))
        (move-card card-id-str p)))))

(define (handle-move-right ev)
  (dom/stop-propagation! ev)
  (dom/prevent-default! ev)
  (when-let (card-id-str (get-card-id-from-event ev))
    (when-let (card (find-card-by-id @board card-id-str))
      (when-let (n (next-col (get card :column)))
        (move-card card-id-str n)))))

(define (handle-delete ev)
  (dom/stop-propagation! ev)
  (dom/prevent-default! ev)
  (when-let (card-id-str (get-card-id-from-event ev))
    (delete-card card-id-str)))

;; Add card flow
(define (start-add-todo ev) (put! adding-col "todo"))
(define (start-add-progress ev) (put! adding-col "in-progress"))
(define (start-add-done ev) (put! adding-col "done"))

(define (handle-add-input ev)
  (put! adding-text (dom/event-value ev)))

(define (submit-add-card ev)
  (dom/prevent-default! ev)
  (let ((text @adding-text)
        (col @adding-col))
    (when (not (equal? text ""))
      (add-card col text)
      (put! adding-text "")
      (put! adding-col nil))))

(define (cancel-add-card ev)
  (put! adding-text "")
  (put! adding-col nil))

(define (handle-add-keydown ev)
  (let ((key (dom/event-key ev)))
    (cond
      ((equal? key "Enter") (submit-add-card ev))
      ((equal? key "Escape") (cancel-add-card ev))
      (#t nil))))

;; Modal handlers
(define (close-modal ev)
  (put! selected-card-id nil))

(define (handle-modal-desc ev)
  (when-let (id @selected-card-id)
    (update-card-field id :description (dom/event-value ev))))

(define (handle-modal-move-left ev)
  (when-let (id @selected-card-id)
    (when-let (card (find-card-by-id @board id))
      (when-let (p (prev-col (get card :column)))
        (move-card id p)))))

(define (handle-modal-move-right ev)
  (when-let (id @selected-card-id)
    (when-let (card (find-card-by-id @board id))
      (when-let (n (next-col (get card :column)))
        (move-card id n)))))

(define (handle-cycle-priority ev)
  (when-let (id @selected-card-id)
    (when-let (card (find-card-by-id @board id))
      (let ((prio (get card :priority)))
        (let ((new-prio (cond
                          ((equal? prio "low") "medium")
                          ((equal? prio "medium") "high")
                          ((equal? prio "high") "urgent")
                          (#t "low"))))
          (update-card-field id :priority new-prio))))))

;; Keyboard shortcuts
(define (handle-global-keydown ev)
  (let ((key (dom/event-key ev)))
    (cond
      ((equal? key "Escape")
       (cond
         ((not (null? @selected-card-id)) (put! selected-card-id nil))
         ((not (null? @adding-col)) (cancel-add-card ev))
         (@search-active (put! search-text ""))
         (#t nil)))
      ((equal? key "/")
       (when-let (input (dom/query "#search-input"))
         (dom/prevent-default! ev)
         (dom/focus! input)))
      ((equal? key "n")
       ;; Only trigger if not typing in an input/textarea
       (when-let (target (dom/event-target ev))
         (let ((tag (dom/get-attribute target "tagName")))
           (when (not (equal? tag "INPUT"))
             (when (not (equal? tag "TEXTAREA"))
               (put! adding-col "todo"))))))
      (#t nil))))

;; ── AI Task Generation ──────────────────────────────────────────────

(define (build-board-context)
  (let ((existing (map (fn (c)
          (string-append "[" (get c :column) "] " (get c :title) " (" (get c :priority) ")"))
        @board)))
    (foldl (fn (acc s) (string-append acc s "\n")) "" existing)))

(define (ai-generate-tasks ev)
  (when (not @ai-loading)
    (put! ai-loading #t)
    (let ((context (build-board-context)))
      (let ((prompt (string-append
              "You are a project manager. Here is the current board:\n\n"
              context
              "\nGenerate 3 NEW tasks that complement this board. "
              "They must be DIFFERENT from existing tasks. "
              "Return ONLY a JSON array: [{\"title\":\"...\",\"priority\":\"low|medium|high|urgent\"}]\n"
              "No markdown fences, no explanation, just the raw JSON array.")))
        (let ((s (llm/chat-stream (list {:role "user" :content prompt}) {})))
          (put! ai-stream s))))))

;; Process completed AI stream — called via js/set-interval polling, NOT during render
(define (poll-ai-stream)
  (when-let (s @ai-stream)
    (let ((val @s))
      (when (get val :done)
        (let ((text (get val :text)))
          (when (not (equal? text ""))
            ;; Try to extract JSON from the response (may contain markdown fences)
            (let ((clean (if (string/contains? text "[")
                          (substring text
                            (string/index-of text "[")
                            (+ 1 (string/last-index-of text "]")))
                          text)))
              (let ((tasks (try (json/decode clean) (catch e nil))))
                (when (and (not (null? tasks)) (list? tasks))
                  (map (fn (task)
                    (let ((card {:id (gen-id)
                                 :title (if (null? (get task :title)) "Untitled" (get task :title))
                                 :description ""
                                 :column "todo"
                                 :priority (if (null? (get task :priority)) "medium" (get task :priority))
                                 :created-at @tick
                                 :ai-generated #t}))
                      (update! board (fn (b) (append b (list card))))))
                    tasks))))))
        (put! ai-stream nil)
        (put! ai-loading #f)))))

;; Poll every 500ms for AI stream completion (avoids side effects during render)
(js/set-interval "poll-ai-stream" 500)

(define (render-ai-status)
  (if-let (s @ai-stream)
    (let ((val @s))
      (if (get val :done)
        [:span {:class streaming-indicator-style} "Processing..."]
        [:span {:class streaming-indicator-style} "Generating tasks..."]))
    [:span]))

