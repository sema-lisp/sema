;; sema-docs-pipeline.sema — a longer, multi-phase dynamic-workflow showcase.
;;
;; Dogfooding + public-safe: Sema drafts, reviews, revises, and assembles short
;; explainers for its OWN features. Unlike the single-phase content pipeline, this
;; exercises the whole dashboard — agents in FOUR phases, journaled tool calls
;; (tool twigs in the drill-in), and a fan-in synthesis step.
;;
;;   Topics    inventory of Sema features (deterministic)
;;   Draft     1 LLM agent per topic — a first-draft explainer       (pipeline fan-out)
;;   Review    1 LLM agent per draft  — a critique + improvement note (pipeline fan-out)
;;   Revise    1 LLM agent per draft  — revise using the critique     (pipeline fan-out)
;;   Assemble  1 LLM agent            — a docs intro over all topics   (fan-in)
;;   Publish   write out/<slug>.md + out/index.md                     (deterministic)
;;
;; Written in the workflow.js-style surface: marker phases, lexical `def` threading,
;; and `pipeline` fan-out. The leaf agents stay on the lower-level `workflow/agent`
;; wrapper because they journal a representative `workflow/tool-call` (tool twigs in
;; the drill-in) — until real tool-using agents land, that's the richer-leaf path.
;;
;; Run it live in the dashboard:
;;   export OPENAI_API_KEY=...
;;   sema workflow run examples/workflows/sema-docs-pipeline.sema --view

;; A small, fast model: cheap to run, good enough for short explainers, not garbage.
(llm/configure :openai
  {:api-key (env "OPENAI_API_KEY") :default-model "gpt-5.4-mini"})

(define topics
  (list "tail-call optimization"
    "NaN-boxed values"
    "the cooperative async scheduler"
    "pattern matching with match"))

(define (ask prompt) (llm/complete prompt))
(define (slug s)
  (string/replace (string/replace (string/lower s) "/" "-") " " "-"))
(define (drafted? d) (and (map? d) (contains? d :draft)))
(define (reviewed? r) (and (map? r) (contains? r :notes)))
(define (revised? r) (and (map? r) (contains? r :body)))

;; --- leaf agents (each journals a representative tool call so the drill-in is rich) ---

(define (write-draft topic)
  (workflow/agent (str "draft: " topic)
    (fn ()
      (workflow/tool-call "recall-spec" topic)
      {:topic topic
       :draft (ask
         (str "Write a 90-word first-draft explainer about the Sema language "
           "feature \""
           topic
           "\". Sema is a homoiconic Lisp on a bytecode "
           "VM. Mention the feature. Plain prose, no headings."))})))

(define (review-draft d)
  (workflow/agent (str "review: " (:topic d))
    (fn ()
      (workflow/tool-call "read-draft" (:topic d))
      {:topic (:topic d)
       :draft (:draft d)
       :notes (ask
         (str "In 30 words, critique this draft for accuracy and clarity and "
           "suggest ONE concrete improvement.\n\n"
           (:draft d)))})))

(define (revise r)
  (workflow/agent (str "revise: " (:topic r))
    (fn ()
      {:topic (:topic r)
       :body (ask
         (str "Revise the draft using the critique. ~100 words, plain prose, "
           "mention the feature.\n\nDRAFT:\n"
           (:draft r)
           "\n\nCRITIQUE:\n"
           (:notes r)))})))

(defworkflow sema-docs-pipeline
  "Draft, review, revise, and assemble explainers for Sema's own features."
  {:phases ["Topics" "Draft" "Review" "Revise" "Assemble" "Publish"] :args {}}

  (phase "Topics")
  (def chosen topics)

  (phase "Draft")
  ;; fan out: <=8 model calls at once; keep only the drafts that came back well-formed.
  ;; `pipeline` yields nil for a failed leaf, which drafted? drops.
  (def drafts (filter drafted? (pipeline chosen (fn (t) (write-draft t)))))

  (phase "Review")
  (def reviews (filter reviewed? (pipeline drafts (fn (d) (review-draft d)))))

  (phase "Revise")
  (def final (filter revised? (pipeline reviews (fn (r) (revise r)))))

  (phase "Assemble")
  ;; fan-in: one agent synthesizes a docs intro, recalling each revised draft.
  (def index
    (workflow/agent {:name "assembler"}
      (fn ()
        (for-each
          (fn (f) (workflow/tool-call "recall-draft" (:topic f)))
          final)
        (ask
          (str
            "Write a 60-word introduction for a docs page covering these Sema "
            "features: "
            (string/join (map (fn (f) (:topic f)) final) ", ")
            ".")))))

  (phase "Publish")
  (file/mkdir "out")
  (for-each
    (fn (f)
      (file/write (str "out/" (slug (:topic f)) ".md")
        (str "# " (:topic f) "\n\n" (:body f) "\n")))
    final)
  (file/write "out/index.md" (str "# Sema Features\n\n" index "\n"))

  {:status :success
   :topics (count chosen)
   :reviewed (count reviews)
   :published (count final)})
