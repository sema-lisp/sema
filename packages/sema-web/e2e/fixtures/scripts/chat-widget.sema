;; Intercom-style floating chat widget — Sema Web demo
;; Showcases: reactive state, computed values, scoped CSS, components,
;; SIP markup, event handling, LLM streaming, localStorage persistence,
;; and DOM manipulation.

;; ── Reactive State ──────────────────────────────────────────────────

(def messages (state (list)))
(def input-text (state ""))
(def is-open (state #f))
(def current-stream (state nil))
(def unread-count (state 0))

;; ── Computed State ──────────────────────────────────────────────────

(def has-unread (computed (> @unread-count 0)))

;; ── LocalStorage Persistence ────────────────────────────────────────

(define (save-messages)
  (store/set! "sema-chat-messages" @messages))

(define (load-messages)
  (when-let (saved (store/get "sema-chat-messages"))
    (put! messages saved)))

(load-messages)

;; ── Scoped CSS ──────────────────────────────────────────────────────

(def fab-style
  (css {:position "fixed"
        :bottom "24px"
        :right "24px"
        :width "60px"
        :height "60px"
        :border-radius "50%"
        :background "linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)"
        :border "none"
        :color "#fff"
        :font-size "28px"
        :cursor "pointer"
        :box-shadow "0 4px 16px rgba(99,102,241,0.4)"
        :z-index "9999"
        :display "flex"
        :align-items "center"
        :justify-content "center"
        :transition "transform 0.2s ease, box-shadow 0.2s ease"
        "&:hover" {:transform "scale(1.08)"
                   :box-shadow "0 6px 24px rgba(99,102,241,0.55)"}}))

(def badge-style
  (css {:position "absolute"
        :top "-4px"
        :right "-4px"
        :background "#ef4444"
        :color "#fff"
        :font-size "12px"
        :font-weight "700"
        :min-width "20px"
        :height "20px"
        :border-radius "10px"
        :display "flex"
        :align-items "center"
        :justify-content "center"
        :padding "0 5px"
        :line-height "1"}))

(def panel-style
  (css {:position "fixed"
        :bottom "96px"
        :right "24px"
        :width "380px"
        :height "520px"
        :background "#18181b"
        :border "1px solid #27272a"
        :border-radius "16px"
        :box-shadow "0 12px 48px rgba(0,0,0,0.5)"
        :display "flex"
        :flex-direction "column"
        :z-index "9998"
        :overflow "hidden"
        :animation "slideUp 0.25s ease-out"}))

(def header-style
  (css {:display "flex"
        :align-items "center"
        :justify-content "space-between"
        :padding "16px 20px"
        :background "linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)"
        :color "#fff"}))

(def header-title-style
  (css {:font-size "15px"
        :font-weight "600"
        :letter-spacing "0.01em"}))

(def close-btn-style
  (css {:background "none"
        :border "none"
        :color "rgba(255,255,255,0.85)"
        :font-size "20px"
        :cursor "pointer"
        :padding "0"
        :line-height "1"
        "&:hover" {:color "#fff"}}))

(def msg-list-style
  (css {:flex "1"
        :overflow-y "auto"
        :padding "16px"
        :display "flex"
        :flex-direction "column"
        :gap "10px"}))

(def msg-user-style
  (css {:align-self "flex-end"
        :background "linear-gradient(135deg, #6366f1 0%, #818cf8 100%)"
        :color "#fff"
        :padding "10px 14px"
        :border-radius "16px 16px 4px 16px"
        :max-width "80%"
        :font-size "14px"
        :line-height "1.45"
        :word-wrap "break-word"}))

(def msg-assistant-style
  (css {:align-self "flex-start"
        :background "#27272a"
        :color "#e4e4e7"
        :padding "10px 14px"
        :border-radius "16px 16px 16px 4px"
        :max-width "80%"
        :font-size "14px"
        :line-height "1.45"
        :word-wrap "break-word"}))

(def msg-streaming-style
  (css {:align-self "flex-start"
        :background "#27272a"
        :color "#e4e4e7"
        :padding "10px 14px"
        :border-radius "16px 16px 16px 4px"
        :max-width "80%"
        :font-size "14px"
        :line-height "1.45"
        :word-wrap "break-word"
        :border "1px solid #6366f1"}))

(def typing-dot-style
  (css {:display "inline-block"
        :width "6px"
        :height "6px"
        :background "#a1a1aa"
        :border-radius "50%"
        :margin-right "4px"
        :animation "blink 1.2s infinite"}))

(def input-area-style
  (css {:display "flex"
        :gap "8px"
        :padding "12px 16px"
        :border-top "1px solid #27272a"
        :background "#18181b"}))

(def input-style
  (css {:flex "1"
        :padding "10px 14px"
        :background "#27272a"
        :border "1px solid #3f3f46"
        :border-radius "12px"
        :color "#fafafa"
        :font-size "14px"
        :outline "none"
        "&:focus" {:border-color "#6366f1"}}))

(def send-btn-style
  (css {:background "linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)"
        :border "none"
        :color "#fff"
        :width "40px"
        :height "40px"
        :border-radius "12px"
        :cursor "pointer"
        :display "flex"
        :align-items "center"
        :justify-content "center"
        :font-size "18px"
        :flex-shrink "0"
        :transition "opacity 0.15s"
        "&:hover" {:opacity "0.85"}}))

;; ── Event Handlers ──────────────────────────────────────────────────

(define (toggle-chat ev)
  (let ((opening (not @is-open)))
    (put! is-open opening)
    (when opening
      (put! unread-count 0))))

(define (close-chat ev)
  (put! is-open #f))

(define (update-input ev)
  (put! input-text (dom/event-value ev)))

(define (scroll-to-bottom)
  (let ((el (dom/query "#widget-msg-list")))
    (when (not (null? el))
      (dom/set-attribute! el "scrollTop" "999999"))))

(define (handle-keydown ev)
  (when (equal? (dom/event-value ev) "Enter")
    (send-message ev)))

(define (send-message ev)
  (dom/prevent-default! ev)
  (let ((text @input-text))
    (when (not (equal? text ""))
      (let ((user-msg {:role "user" :content text}))
        (update! messages (fn (msgs) (append msgs (list user-msg))))
        (put! input-text "")
        (save-messages)
        (let ((s (llm/chat-stream (list {:role "user" :content text}) {})))
          (put! current-stream s))))))

;; ── Stream Rendering ────────────────────────────────────────────────

(define (render-stream)
  (if-let (s @current-stream)
    (let ((val @s))
      (if (get val :done)
        (begin
          (when (not (equal? (get val :text) ""))
            (update! messages
              (fn (msgs)
                (append msgs (list {:role "assistant" :content (get val :text)}))))
            (save-messages))
          (put! current-stream nil)
          [:span])
        (if (equal? (get val :text) "")
          [:div {:class msg-streaming-style :data-testid "typing-indicator"}
            [:span {:class typing-dot-style} ""]
            [:span {:class typing-dot-style} ""]
            [:span {:class typing-dot-style} ""]]
          [:div {:class msg-streaming-style :data-testid "streaming-msg"}
            [:span (get val :text)]])))
    [:span]))

;; ── Message Rendering ───────────────────────────────────────────────

(define (render-message msg)
  (let ((role (get msg :role))
        (content (get msg :content)))
    (if (equal? role "user")
      [:div {:class msg-user-style :data-testid "msg-user"} content]
      [:div {:class msg-assistant-style :data-testid "msg-assistant"} content])))

;; ── Components ──────────────────────────────────────────────────────

(define (chat-panel)
  (if @is-open
    [:div {:class panel-style :data-testid "chat-panel"}
      [:div {:class header-style}
        [:span {:class header-title-style} "Sema Chat"]
        [:button {:class close-btn-style :on-click "close-chat" :data-testid "close-btn"
                  :aria-label "Close chat"} "\u00D7"]]
      [:div {:class msg-list-style :id "widget-msg-list"}
        (map render-message @messages)
        (render-stream)]
      [:form {:class input-area-style :on-submit "send-message"}
        [:input {:class input-style
                 :id "widget-input"
                 :type "text"
                 :placeholder "Type a message..."
                 :value @input-text
                 :on-input "update-input"
                 :autocomplete "off"
                 :data-testid "chat-input"}]
        [:button {:class send-btn-style
                  :type "submit"
                  :data-testid "send-btn"
                  :aria-label "Send message"} "\u25B6"]]]
    [:span]))

(define (chat-fab)
  [:div
    [:button {:class fab-style :on-click "toggle-chat"
              :data-testid "chat-fab"
              :aria-label "Open chat"}
      (if @is-open "\u00D7" "\u2709")
      (when @has-unread
        [:span {:class badge-style :data-testid "unread-badge"}
          (number->string @unread-count)])]])

(define (widget-root)
  [:div
    (chat-fab)
    (chat-panel)])

(mount! "#chat-widget" widget-root)
