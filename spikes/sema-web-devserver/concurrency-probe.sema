;; concurrency-probe.sema — does http/serve handle requests concurrently?
;;
;; The dev server must hold a long-lived hot-reload connection open AND keep
;; serving static files + LLM-proxy calls. This probe tests whether an in-flight
;; SSE stream blocks a concurrent plain request.
;;
;; Run:   sema spikes/sema-web-devserver/concurrency-probe.sema
;; Probe: see run-concurrency-probe.sh

(define (handle-hello req)
  (http/html "hello"))

;; SSE stream that stays "open" for ~3s, emitting a tick each second.
(define (handle-slow-sse req)
  (http/stream
    (fn (send)
      (send "tick-1")
      (sleep 1000)
      (send "tick-2")
      (sleep 1000)
      (send "tick-3"))))

(define routes
  [[:get "/hello" handle-hello]
   [:get "/sse"   handle-slow-sse]])

(println "probe server on http://127.0.0.1:3011")
(http/serve (http/router routes) {:port 3011 :host "127.0.0.1"})
