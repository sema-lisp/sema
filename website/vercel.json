{
  "buildCommand": "npm run build",
  "outputDirectory": ".vitepress/dist",
  "installCommand": "npm install",
  "framework": null,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/.well-known/ai-catalog.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/install.sh",
      "destination": "https://github.com/sema-lisp/sema/releases/latest/download/sema-lang-installer.sh",
      "statusCode": 302
    },
    {
      "source": "/install.ps1",
      "destination": "https://github.com/sema-lisp/sema/releases/latest/download/sema-lang-installer.ps1",
      "statusCode": 302
    }
  ]
}
